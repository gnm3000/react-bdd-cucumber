{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "rootDir": ".",
    "outDir": "generated/node",
    "types": ["node"]
  },
  "include": ["vite.config.ts", "playwright.config.ts", "cucumber.cjs", "features/**/*.ts"]
}
